<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Green → yellow-gold diagonal gradient background -->
    <path android:pathData="M0,0h108v108h-108z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="0"
                android:startY="0"
                android:endX="108"
                android:endY="108">
                <item android:offset="0.0"  android:color="#1B6840"/>
                <item android:offset="0.55" android:color="#42A068"/>
                <item android:offset="1.0"  android:color="#F0C135"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- Soft radial highlight in upper-left for depth -->
    <path android:pathData="M0,0h108v108h-108z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="18"
                android:centerY="18"
                android:gradientRadius="72">
                <item android:offset="0.0" android:color="#33FFFFFF"/>
                <item android:offset="1.0" android:color="#00FFFFFF"/>
            </gradient>
        </aapt:attr>
    </path>

</vector>
