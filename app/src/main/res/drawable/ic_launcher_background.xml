<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Earth-to-sky diagonal: deep green (bottom-left) → golden sunrise (top-right) -->
    <path android:pathData="M0,0h108v108h-108z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="0"
                android:startY="108"
                android:endX="108"
                android:endY="0">
                <item android:offset="0.0"  android:color="#165230"/>
                <item android:offset="0.50" android:color="#2E8B55"/>
                <item android:offset="0.82" android:color="#C8A020"/>
                <item android:offset="1.0"  android:color="#F5D040"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- Soft radial glow where the sun will appear (top-centre of foreground) -->
    <path android:pathData="M0,0h108v108h-108z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="54"
                android:centerY="38"
                android:gradientRadius="52">
                <item android:offset="0.0" android:color="#44FFEE88"/>
                <item android:offset="1.0" android:color="#00FFEE88"/>
            </gradient>
        </aapt:attr>
    </path>

</vector>
