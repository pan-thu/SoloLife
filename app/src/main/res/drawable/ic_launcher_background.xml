<?xml version="1.0" encoding="utf-8"?>
<!-- Shape drawable gradient — reliable on all AGP versions, no aapt:attr needed.
     angle=45 → bottom-left (deep green / earth) to top-right (golden yellow / sky). -->
<shape xmlns:android="http://schemas.android.com/apk/res/android">
    <gradient
        android:type="linear"
        android:startColor="#165230"
        android:centerColor="#2E8B55"
        android:endColor="#F2C132"
        android:angle="45"/>
</shape>
