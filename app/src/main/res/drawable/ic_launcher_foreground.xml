<?xml version="1.0" encoding="utf-8"?>
<!--
    "Dawn Pages" — a sunrise rising from an open journal.
    Metaphor: every day is a new page; the sun represents new beginnings.

    Viewport 108×108. Safe zone: 18–90 (72dp centred).
    Foreground is all-white (with alpha) for correct monochrome icon tinting.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- ── Sun disc ──────────────────────────────────────────────────────── -->
    <path
        android:pathData="M54,46 m-13,0 a13,13 0 1,0 26,0 a13,13 0 1,0 -26,0"
        android:fillColor="#FFFFFF"
        android:fillAlpha="0.97"/>

    <!-- ── Sun rays: 5 rays fanning upward from the sun ─────────────────── -->
    <!--   Centre (54,46). Inner radius ~18, outer ~26.                      -->
    <!--   Angles from north (0°=up): 0°, ±38°, ±76°                        -->
    <path
        android:pathData="M54,28 L54,20
                          M65,32 L70,26
                          M43,32 L38,26
                          M72,43 L79,41
                          M36,43 L29,41"
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="2.8"
        android:strokeAlpha="0.94"
        android:strokeLineCap="round"/>

    <!-- ── Left page — curved wing, wider at outer edge ─────────────────── -->
    <path
        android:pathData="M54,63 C43,62 27,66 20,75 L20,85 C28,83 43,81 54,81 Z"
        android:fillColor="#FFFFFF"
        android:fillAlpha="0.96"/>

    <!-- ── Right page — mirror, slightly less opaque for depth ───────────── -->
    <path
        android:pathData="M54,63 C65,62 81,66 88,75 L88,85 C80,83 65,81 54,81 Z"
        android:fillColor="#FFFFFF"
        android:fillAlpha="0.80"/>

    <!-- ── Spine shadow (thin dark wedge between pages) ──────────────────── -->
    <path
        android:pathData="M52,63 C51.5,72 52,81 L56,81 C55.5,72 56,63 Z"
        android:fillColor="#000000"
        android:fillAlpha="0.09"/>

    <!-- ── Spine crease ───────────────────────────────────────────────────── -->
    <path
        android:pathData="M54,63 L54,81"
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1.0"
        android:strokeAlpha="0.28"
        android:strokeLineCap="round"/>

    <!-- ── Left page: two writing lines ──────────────────────────────────── -->
    <path
        android:pathData="M27,72 L49,72 M27,79 L39,79"
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="2.2"
        android:strokeAlpha="0.42"
        android:strokeLineCap="round"/>

    <!-- ── Right page: two writing lines ─────────────────────────────────── -->
    <path
        android:pathData="M59,72 L81,72 M69,79 L81,79"
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="2.2"
        android:strokeAlpha="0.42"
        android:strokeLineCap="round"/>

    <!-- ── Small horizon line joining the two page bases at the spine ─────── -->
    <!--   Suggests the ground/horizon the sun rises above.                   -->
    <path
        android:pathData="M34,63 L74,63"
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1.8"
        android:strokeAlpha="0.30"
        android:strokeLineCap="round"/>

</vector>
